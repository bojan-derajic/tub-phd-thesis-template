{
  "name": "Thesis",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "workspaceFolder": "/workspaces/thesis",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/thesis,type=bind",
  "customizations": {
    "vscode": {
      "extensions": [
        "james-yu.latex-workshop",
        "ms-vscode.makefile-tools",
      ],
      "settings": {
        // Use latexmk as the single build recipe (handles biber automatically)
        "latex-workshop.latex.recipes": [
          {
            "name": "latexmk",
            "tools": [
              "latexmk",
              "copy-pdf"
            ]
          }
        ],
        "latex-workshop.latex.tools": [
          {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
              "-pdf",
              "-interaction=nonstopmode",
              "-synctex=1",
              "-output-directory=build",
              "%DOC%"
            ]
          },
          {
            "name": "copy-pdf",
            "command": "cp",
            "args": [
              "build/%DOCFILE%.pdf",
              "."
            ]
          }
        ],
        "latex-workshop.latex.autoBuild.run": "onSave",
        "latex-workshop.view.pdf.viewer": "tab",
        "latex-workshop.formatting.latex": "latexindent"
      }
    }
  }
}